NODE_ENV=production
PORT=3000

ANA_IDENTIFICADOR=seu_usuario_ana
ANA_SENHA=sua_senha_ana

# Publicas e incorporadas ao bundle Expo durante o build.
EXPO_PUBLIC_PROXY_URL=
