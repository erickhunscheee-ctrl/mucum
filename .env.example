ANA_IDENTIFICADOR=seu_usuario_ana
ANA_SENHA=sua_senha_ana
# Desenvolvimento local: http://localhost:3001
# Docker/Easypanel: deixe vazio para usar /api no mesmo dominio.
EXPO_PUBLIC_PROXY_URL=http://localhost:3001

# Publicas: podem ir para web/mobile. Pegue em Supabase > Project Settings > API.
EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key

# Privada: somente processo Node local ou no servidor. Nunca usar no app.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
